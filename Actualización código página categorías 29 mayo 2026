<script>
  function desplegarReproductor(categoria, nombrePrograma) {
    // 1. Ubicar todos los contenedores de reproductor
    const todosLosReproductores = document.querySelectorAll('.detalle-reproductor');
    // 2. Ubicar el reproductor específico al que se le hizo clic
    const reproductorObjetivo = document.getElementById('reproductor-' + categoria);
    
    if (!reproductorObjetivo) return; // Control de seguridad

    // Verificar si ya está visible
    const yaEstaAbierto = window.getComputedStyle(reproductorObjetivo).display === 'block';

    // 3. Ocultar todos los reproductores primero
    todosLosReproductores.forEach(rep => {
      rep.style.display = 'none';
    });

    // 4. Si no estaba abierto, mostrarlo y cambiar dinámicamente el título interno
    if (!yaEstaAbierto) {
      reproductorObjetivo.style.display = 'block';
      
      const campoTitulo = document.getElementById('titulo-repro-' + categoria);
      if (campoTitulo) {
        campoTitulo.innerText = nombrePrograma;
      }

      // Desplazamiento suave al reproductor
      reproductorObjetivo.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }
</script>
