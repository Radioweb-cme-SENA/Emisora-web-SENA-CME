    background-color: rgba(0, 34, 56, 0.92); 
    border-radius: 8px;
    padding: 20px;
    max-height: 250px;
    overflow-y: auto;
    margin-bottom: 25px;
    box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
  }

  .item-capitulo {
    padding: 12px 15px;
    border-bottom: 1px dashed rgba(255,255,255,0.15);
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .item-capitulo:hover { background: rgba(255,255,255,0.12); }
  .item-capitulo:last-child { border-bottom: none; }

  .barra-control {
    background-color: #007832;
    border-radius: 6px;
    padding: 15px 25px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  }

  .controles-reproduccion { display: flex; align-items: center; gap: 20px; font-size: 1.2rem; }
  .controles-reproduccion i { cursor: pointer; transition: transform 0.2s; }
  .controles-reproduccion i:hover { transform: scale(1.15); color: var(--gold); }

  .progreso-audio {
    flex: 1;
    margin: 0 25px;
    height: 5px;
    background: rgba(255,255,255,0.25);
    border-radius: 3px;
    position: relative;
    cursor: pointer;
  }

  .progreso-actual { width: 35%; height: 100%; background: var(--verde-sena); border-radius: 3px; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; gap: 18px; }
    .card { margin: 10px 16px; }
    .info-episodio { flex-direction: column-reverse; align-items: center; text-align: center; }
    .barra-control { flex-direction: column; gap: 15px; }
    .progreso-audio { width: 100%; margin: 10px 0; }
  }

  /* ── FOOTER ── */
  footer {
    background-color: var(--verde-oscuro);
    padding: 40px 20px;
    text-align: center;
    font-family: 'Montserrat', sans-serif;
