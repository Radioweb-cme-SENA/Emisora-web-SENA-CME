  /* ── HERO SECTION ── */
  .hero {
    padding: 60px 20px 30px;
    text-align: center;
  } 

  .hero h1.cat-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--blanco);
    letter-spacing: 0.01em;
    margin-bottom: 8px;
  }

  .hero h2.sub-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 800;
    color: var(--blanco);
    margin-top: 20px;
  }

  /* ── GRID Y CONTENEDORES DE TARJETAS ── */
  .container-card-wrapper {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 0 10px 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 0px;
  }

  /* ── CARD ── */
  .card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.25);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    cursor: pointer;
    animation: fadeUp 0.5s ease both;
    margin: 16px 24px;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(0,0,0,0.35);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .card-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a1a4e 0%, #6b4f10 100%);
  }

  .thumb-placeholder svg { width: 80%; max-width: 200px; opacity: 0.9; }

  .boton-academico, .boton-informativo, .boton-cultural {
    position: absolute;
    bottom: 8px;
    right: 8px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.4);
    transition: transform 0.2s;
  }

  .card:hover .boton-academico,
  .card:hover .boton-informativo,
  .card:hover .boton-cultural { 
    transform: scale(1.15); 
  }

  /* ── AJUSTES DE CONTENIDO DE LAS TARJETAS ── */
.card-body { 
  padding: 20px 18px; /* Más espacio interno para que el texto no toque los bordes */
  display: flex;
  flex-direction: column;
  gap: 6px; /* Crea un espacio uniforme automático entre cada elemento */
}

.card-program { 
  font-family: 'Montserrat', sans-serif; 
  font-weight: 700; 
  font-size: 1.05rem; /* Letra ligeramente más grande para el título del programa */
  color: var(--azul-oscuro); /* Cambiado a azul oscuro para mayor contraste institucional */
  margin: 0; 
}

.card-time { 
  font-family: 'Montserrat', sans-serif; 
  font-weight: 600; 
  font-size: 0.85rem; 
  color: var(--verde-oscuro); 
  margin: 0;
  display: flex;
  align-items: center;
}

.card-desc { 
  font-family: sans-serif;
  font-size: 0.82rem; 
  color: var(--text-muted); 
  line-height: 1.4; /* Espaciado entre líneas para que sea cómodo de leer */
  margin: 4px 0 0 0; 
}

/* ── AJUSTE DEL LOGO (PODIUM) ── */
/* Esto centra el texto horizontal y verticalmente usando CSS, HTML */
.thumb-placeholder svg {
  width: 100%;
  height: 100%;
}

.thumb-placeholder svg text {
  text-anchor: middle;   /* Modifica el punto de anclaje al centro del texto */
  x: 50% !important;    
}
  /* ── SECCIONES DETALLADAS DE REPRODUCCIÓN ── */
  .detalle-reproductor {
    display: none; 
    max-width: 1100px;
    margin: 20px auto 0 auto;
    animation: slideDown 0.4s ease forwards;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #reproductor-academico { 
    background-image: url("https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgWgmtZPa-M2foM3zqyC79DSgqMbAjVecnbRJ33ui7e9dhX7I-sjASye_NbiHThXfI2G8qLFE3AvsulztLmjhfL6e0WtUuaomXP3tL0QW7Za3CqkGvy6jUBRz3JfqTpq2ciPBRR3XoaMhRG5CyL4iycTKByqEPWyZkisd4Gkui4hzB3_90BWtP4R_MDecK8/s400/image%2014.png"), linear-gradient(180deg, #007832 0%, #00304D 100%); 
    border-top: 4px solid var(--verde-sena); 
  }
  #reproductor-informativo { 
