<script>
  document.addEventListener('DOMContentLoaded', function() {
    const track = document.getElementById('bannerTrack');
    const slides = Array.from(document.querySelectorAll('.banner-slide'));
    const dots = Array.from(document.querySelectorAll('.banner-dot'));
    const prevBtn = document.getElementById('bannerPrev');
    const nextBtn = document.getElementById('bannerNext');
    const currentTxt = document.getElementById('bannerCurrent');
    
    let currentIndex = 0;
    const totalSlides = slides.length;

    function updateSlider(index) {
      // Remover clase activa del anterior
      slides[currentIndex].classList.remove('is-active');
      dots[currentIndex].classList.remove('is-active');
      
      // Ajustar index limites
      if(index >= totalSlides) currentIndex = 0;
      else if(index < 0) currentIndex = totalSlides - 1;
      else currentIndex = index;

      // Desplazar el track
      track.style.transform = `translateX(-${currentIndex * 100}%)`;
      
      // Activar nuevo slide y dot
      slides[currentIndex].classList.add('is-active');
      dots[currentIndex].classList.add('is-active');
      
      // Actualizar texto numérico (ej: 01, 02)
      currentTxt.textContent = String(currentIndex + 1).padStart(2, '0');
    }

    // Eventos Click en Botones
    nextBtn.addEventListener('click', () => updateSlider(currentIndex + 1));
    prevBtn.addEventListener('click', () => updateSlider(currentIndex - 1));

    // Eventos Click en Puntos (Dots)
    dots.forEach(dot => {
      dot.addEventListener('click', (e) => {
        const targetIndex = parseInt(e.target.getAttribute('data-index'));
        updateSlider(targetIndex);
      });
    });

    // Transición Automática cada 6 segundos
    setInterval(() => {
      updateSlider(currentIndex + 1);
    }, 6000);
  });
</script>
