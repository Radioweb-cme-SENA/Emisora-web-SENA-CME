<style>
  /* CONTENEDOR DE LA SECCIÓN NOSOTROS  */
  .nosotros-cme {
    --verde-sena: #39A900;
    --verde-oscuro: #007832;
    --azul-oscuro: #00304D;
    --gris-fondo: #F9F9F9;
    --blanco: #FFFFFF;
    --Amarillo :#FCD300;
    
    font-family: 'Work Sans', sans-serif;
    color: #333333;
    /* Fondo con degradado institucional adaptado del componente de contacto */
    background: linear-gradient(180deg, rgba(8, 78, 38, 1) 0%, rgba(57, 169, 0, 1) 100%);
    padding: 60px 0;
    box-sizing: border-box;
  }

  .nosotros-cme .container-identidad { 
    max-width: 1100px; 
    margin: auto; 
    padding: 0 20px; 
  }
  
  /* ESTILO PARA EL TÍTULO DE LA SECCIÓN */
  .nosotros-cme h1 { 
    text-align: center; 
    color: var(--blanco) !important; 
    font-weight: 800; 
    text-transform: uppercase; 
    margin-top: 0;
    margin-bottom: 50px; /* Espacio extra abajo para que no pegue con los botones */
    padding-top: 20px;   /* Espacio arriba para que no pegue con el borde superior */
    padding-bottom: 20px; /* Espacio abajo antes de la línea amarilla */
    font-size: clamp(1.6rem, 4.5vw, 2.5rem); /* Ajustado para mejor respuesta en celular */
    line-height: 1.4; /* Evita que las líneas se peguen en pantallas pequeñas */
    letter-spacing: 0.05em;
    position: relative;
  }

  /* Línea decorativa inferior del título principal */
  .nosotros-cme h1::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 5px;
    background: #f5c300; 
    border-radius: 10px;
  }

  /* REJILLA DINÁMICA DE LOS BOTONES DE MENÚ */
  .nosotros-cme .grid-identidad { 
    display: grid; 
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); /* Columnas responsivas */
    gap: 20px; 
    margin-bottom: 40px; 
  }

  /* TARJETAS INTERACTIVAS */
  .nosotros-cme .card-nosotros { 
    background: rgba(255, 255, 255, 0.15); /* Efecto cristal translúcido sobre el fondo */
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    border-radius: 16px; 
    overflow: hidden; 
    box-shadow: 0px 8px 20px rgba(0,0,0,0.15); 
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); 
    text-align: center; 
    border: 1px solid rgba(255, 255, 255, 0.25);
    cursor: pointer;
  }

  /* Animación al pasar el mouse por encima de los botones superiores */
  .nosotros-cme .card-nosotros:hover { 
    transform: translateY(-8px); 
    background: var(--blanco);
    border-color: var(--blanco);
    box-shadow: 0px 12px 25px rgba(0,0,0,0.25);
  }

  .nosotros-cme .card-content { 
    padding: 25px 15px; 
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* Decorador de icono simulado sobre las tarjetas */
  .nosotros-cme .card-icon {
    font-size: 1.8rem;
    margin-bottom: 10px;
    transition: transform 0.3s ease;
  }
  .nosotros-cme .card-nosotros:hover .card-icon {
    transform: scale(1.2);
  }

  .nosotros-cme .card-nosotros h3 { 
    font-size: 1rem; 
    color: var(--blanco); 
    margin-top: 0;
    margin-bottom: 15px; 
    font-weight: 700; 
    border: none; 
    transition: color 0.3s ease;
  }
  .nosotros-cme .card-nosotros:hover h3 {
    color: var(--azul-oscuro);
  }

  /* ESTILOS DEL BOTÓN REDONDEADO INTERNO */
  .nosotros-cme .boton-id { 
    background: #FCD300; 
    color: var(--azul-oscuro) !important; 
    padding: 10px 20px; 
    border-radius: 50px; 
    border: none; 
    font-weight: 700; 
    cursor: pointer; 
    font-size: 0.8rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    width: 90%;
  }
  .nosotros-cme .card-nosotros:hover .boton-id {
    background: var(--verde-sena);
    color: var(--blanco) !important;
    box-shadow: 0 4px 12px rgba(57, 169, 0, 0.3);
  }

  /* BLOQUES INFORMATIVOS DESPLEGABLES (Ocultos por defecto) */
  .nosotros-cme .seccion-id { 
    display: none; 
    margin-top: 30px; 
    background: var(--blanco); 
    padding: 40px; 
    border-radius: 20px; 
    border: none;
    box-shadow: 0px 15px 35px rgba(0,0,0,0.2); 
    border-top: 8px solid var(--azul-oscuro);
    animation: fadeID 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); 
    scroll-margin-top: 40px; 
  }

  /* CLASE QUE ACTIVA LA VISIBILIDAD MEDIANTE JAVASCRIPT */
  .nosotros-cme .activa-id { display: block !important; }
  
  /* ESTILOS DE SUBTÍTULOS Y TEXTO INTERNO */
  .nosotros-cme h2 { 
    color: var(--azul-oscuro); 
    font-weight: 800; 
    border-bottom: 3px solid var(--verde-sena); 
    display: inline-block; 
    margin-top: 0;
    margin-bottom: 25px; 
    font-size: 24px; 
    padding-bottom: 5px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .nosotros-cme .texto-pro h3 { 
    color: var(--verde-oscuro); 
    font-size: 1.3rem; 
    margin-top: 30px; 
    margin-bottom: 10px;
    font-weight: 700;
    border: none; 
  }
  .nosotros-cme .texto-pro p {
    margin-top: 0;
    margin-bottom: 15px;
  }
  .nosotros-cme .texto-pro { line-height: 1.8; color: #444444; text-align: justify; font-size: 15.5px; }
  
  /* BLOQUES DE ENFASIS (Para objetivos generales y preguntas clave) */
  .nosotros-cme .highlight-box { 
    background: #F4F9F4; 
    padding: 25px; 
    border-radius: 14px; 
    border-left: 6px solid var(--verde-sena); 
    margin: 25px 0; 
    box-shadow: inset 0 0 10px rgba(0,0,0,0.02);
  }
  
  /* EFECTO DE ANIMACIÓN FADE-IN */
  @keyframes fadeID { 
    from { opacity: 0; transform: translateY(20px); } 
    to { opacity: 1; transform: translateY(0); } 
  }

  /* ── RESPONSIVE DESIGN ── */
  @media (max-width: 600px) {
    .nosotros-cme { padding: 40px 0; }
    .nosotros-cme .container-identidad { padding: 0 15px; }
    .nosotros-cme .grid-identidad { grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; }
    .nosotros-cme .card-content { padding: 15px 10px; }
    .nosotros-cme .card-icon { font-size: 1.5rem; margin-bottom: 5px; }
    .nosotros-cme .card-nosotros h3 { font-size: 0.9rem; margin-bottom: 10px; }
    .nosotros-cme .boton-id { padding: 8px 12px; font-size: 0.75rem; }
    .nosotros-cme .seccion-id { padding: 25px 20px; border-radius: 15px; }
    .nosotros-cme h2 { font-size: 20px; }
  }
</style>

