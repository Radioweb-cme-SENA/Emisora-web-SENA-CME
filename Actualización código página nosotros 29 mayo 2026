<script>
function mostrarID(id) {
  // 1. Captura todas las secciones informativas y las oculta por completo
  let secciones = document.querySelectorAll('.seccion-id');
  secciones.forEach(sec => {
    sec.classList.remove('activa-id');
  });
  
  // 2. Busca la sección correspondiente al botón cliqueado
  let elemento = document.getElementById(id);
  if (elemento) {
    // Activa la visibilidad inmediatamente sin esperas
    elemento.classList.add('activa-id'); 
    
    // 3. Desplazamiento automático inmediato a la sección visible
    elemento.scrollIntoView({ behavior: "smooth", block: "start" });
  }
}
</script>
