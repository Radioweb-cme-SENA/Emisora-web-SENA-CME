    // Inserta las etiquetas de los días de la semana
    ["Dom", "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb"].forEach(l => { 
      const e=document.createElement('div'); e.className='day-name'; e.innerText=l; dGrid.appendChild(e); 
    });
    
    const firstDay = new Date(year, month, 1).getDay(); // Día de la semana en que inicia el mes
    const totalDays = new Date(year, month + 1, 0).getDate(); // Total de días del mes actual
    const today = new Date();
    
    // Genera los espacios en blanco necesarios para alinear el día 1
    for(let i=0; i<firstDay; i++) dGrid.appendChild(document.createElement('div'));
    
    // Bucle para inyectar cada uno de los días del mes
    for(let i=1; i<=totalDays; i++) {
      const dayDiv = document.createElement('div');
      dayDiv.className = 'calendar-day';
      dayDiv.innerText = i;
      const key = `${month}-${i}`;
      
      // Clasificación condicional de los estilos del casillero
      if(programacionData[key]) dayDiv.classList.add('has-event');
      if(i === today.getDate() && month === today.getMonth() && year === today.getFullYear()) dayDiv.classList.add('today');
      else if(holidays2026.includes(key)) dayDiv.classList.add('holiday');
      
      dayDiv.onclick = () => showPrograms(key, i);
      dGrid.appendChild(dayDiv);
    }
  }

  // Despliega las tarjetas de eventos correspondientes al presionar un día activo
  function showPrograms(key, day) {
    const container = document.getElementById('programsContainer');
    document.getElementById('selected-date-title').innerText = `Programación del día ${day}`;
    container.innerHTML = "";
    
    if(programacionData[key]) {
      programacionData[key].forEach(p => {
        container.innerHTML += `<div class="program-card"><img src="${p.img}" onerror="this.src='https://via.placeholder.com/400x200?text=Podium+Radio'"><div class="program-info"><h4>${p.titulo}</h4><span class="time">⏰ ${p.hora}</span><p class="desc">${p.desc}</p></div></div>`;
      });
    } else { 
      container.innerHTML = "<p style='color: #FFFFFF; text-align: center; width: 100%; font-weight: 600;'>No hay eventos registrados para esta fecha.</p>"; 
    }
  }

  // Controla la visibilidad de las listas de reproducción de SoundCloud (Tipo acordeón)
  function toggleSection(id) {
    const lists = document.querySelectorAll('.podcast-list');
    lists.forEach(l => l.style.display = (l.id === id && l.style.display !== 'block') ? 'block' : 'none');
  }

  // Ejecuta la navegación hacia adelante o hacia atrás en los meses
  function changeMonth(v) { 
    navDate.setMonth(navDate.getMonth() + v); 
    renderCalendar(); 
  }
  
  // Inicialización automática al cargar el módulo
  renderCalendar();
</script>
